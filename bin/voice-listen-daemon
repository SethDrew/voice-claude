#!/bin/bash
INSTALL_DIR="$HOME/.local/share/voice-claude"
source "$INSTALL_DIR/venv/bin/activate"

while true; do
    PYTHONPATH="$INSTALL_DIR" python "$INSTALL_DIR/listen_daemon.py" "$@"
    EXIT_CODE=$?
    [ $EXIT_CODE -eq 0 ] && break
    echo "[voice-listen-daemon] crashed (exit $EXIT_CODE), restarting in 1s..." >&2
    sleep 1
done
